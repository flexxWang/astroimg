NODE_ENV=production
PORT=4000
LOG_LEVEL=info
MONITORING_ENABLED=true
MONITORING_SERVICE_NAME=astroimg-backend
MONITORING_ENVIRONMENT=production
METRICS_TOKEN=replace-with-secret
METRICS_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
TRUST_PROXY=true
CORS_ALLOWED_ORIGINS=https://app.example.com
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=astroimg
DB_PASS=replace-with-secret
DB_NAME=astroimg
DB_LOGGING=false
DB_SYNC=false
DB_RUN_MIGRATIONS=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=replace-with-secret
MINIO_SECRET_KEY=replace-with-secret
MINIO_BUCKET=astroimg
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://assets.example.com

UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,image/tiff,application/fits,application/x-fits
UPLOAD_MAX_BYTES=52428800
UPLOAD_PRESIGN_TTL_SECONDS=600

AI_PROVIDER=openrouter
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-20b:free
